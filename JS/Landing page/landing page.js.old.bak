    "MAINTENANCE NOTICE: Mandatory computer diagnostics initiated site-wide. All non-essential desktop applications must be closed.": 
        "MAINTENANCE COMPLETE: Site-wide diagnostics successfully finished.",
    "MAINTENANCE NOTICE: Cafeteria 'Gamma' sanitation protocol active. Food services unavailable in this area until 13:00 hours.": 
        "MAINTENANCE COMPLETE: Cafeteria 'Gamma' sanitation complete. Food services restored.",

    "MTF-Alpha-1 ('Red Right Hand') deployed to assist with anomalous activity in Sector 7. Clearance level 3 or below are restricted from all adjacent zones.": 
        "MTF A-1 STAND DOWN: MTF Alpha-1 ('Red Right Hand') mission concluded. Anomalous activity in Sector 7 neutralized.",
    "MTF-Epsilon-11 ('Nine Tailed Fox') mobilized for internal security drill in response to a simulated Keter breach in Sector 6.": 
        "MTF E-11 STAND DOWN: MTF Epsilon-11 ('Nine Tailed Fox') internal security drill concluded. All simulated anomalies secured.",
    "MTF-Zeta-9 ('Mole Rats') deployed to investigate structural instability in Sub-Level 7. Evacuate all personnel from Sub-Level 6.": 
        "MTF Z-9 STAND DOWN: MTF Zeta-9 ('Mole Rats') investigation concluded. Structural instability secured and personnel returned to duty."
};

function shuffleArray(array) {
    for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[i], array[j]];
    }
}

function replenishAlerts() {
    availableAlerts = Object.keys(ALERT_MAPPING);
    shuffleArray(availableAlerts);
}

function saveAppState() {
    if (!alertList || !siteStatusEl) return;
    
    const currentAlerts = Array.from(alertList.querySelectorAll('li')).map(li => li.innerHTML);

    const appState = {
        alertMessages: currentAlerts,
        unreadCount: unreadAlertCount,
        isBreach: isBreachActive, 
        siteStatusText: siteStatusEl.textContent,
        siteStatusClass: Array.from(siteStatusEl.classList).find(c => c.startsWith('status-')) || '',
        siteStatusStyleColor: siteStatusEl.style.color || '', 
        siteStatusStyleBorder: siteStatusEl.style.borderColor || ''
    };
    localStorage.setItem('scpAppState', JSON.stringify(appState));
}

function loadAppState() {
    const savedState = localStorage.getItem('scpAppState');
    if (!savedState) return;

    const state = JSON.parse(savedState);

    if (state.alertMessages && alertList) {
        alertList.innerHTML = '';
        state.alertMessages.reverse().forEach(messageHTML => {
            const listItem = document.createElement('li');
            listItem.innerHTML = messageHTML;
            alertList.prepend(listItem);
        });

        if (state.alertMessages.length > 0 && noAlertsMsg) {
            noAlertsMsg.classList.add('hidden');
        }
    }

    unreadAlertCount = state.unreadCount || 0;
    if (alertCountEl) {
        alertCountEl.textContent = unreadAlertCount;
        if (unreadAlertCount > 0) {
            alertCountEl.classList.remove('hidden');
        } else {
            alertCountEl.classList.add('hidden');
        }
    }

    isBreachActive = state.isBreach || false;
    if (siteStatusEl) {
        siteStatusEl.textContent = state.siteStatusText;
        siteStatusEl.classList.remove('status-red', 'status-yellow', 'status-green'); 
        siteStatusEl.style.color = state.siteStatusStyleColor || ''; 
        siteStatusEl.style.borderColor = state.siteStatusStyleBorder || '';
        
        if (state.siteStatusClass) {
            siteStatusEl.classList.add(state.siteStatusClass);
        }
        
        if (isBreachActive) {
            setTimeout(startLockdownCountdown, 5000); 
        }
    }
}

function updateTime() {
    const now = new Date();
    const date = now.toLocaleDateString('en-US', { day: '2-digit', month: '2-digit', year: 'numeric' }).replace(/\//g, '-');
    const time = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    if (serverTimeEl) {
        serverTimeEl.textContent = `${date} ${time}`;
    }
}

function showToastNotification(message) {
    if (toastNotification) {
        let displayMessage = message.replace(/\*\*/g, ''); 
        
        toastNotification.textContent = displayMessage;
        toastNotification.classList.remove('hidden');
        toastNotification.classList.add('active');

        setTimeout(() => {
            toastNotification.classList.remove('active');
            setTimeout(() => {
                toastNotification.classList.add('hidden');
            }, 500);
        }, 5000);
    }
}

function logAlert(message) {
    const now = new Date();
    const time = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    
    if (alertList) {
        const listItem = document.createElement('li');
        listItem.innerHTML = `**[${time}]** ${message}`;
        
        alertList.prepend(listItem);
        
        if (noAlertsMsg) noAlertsMsg.classList.add('hidden');
        
        unreadAlertCount++;
        if (alertCountEl) {
            alertCountEl.textContent = unreadAlertCount;
            alertCountEl.classList.remove('hidden');
        }
        
        saveAppState(); 
    }
    
    showToastNotification(message); 
}

function startLockdownCountdown() {
    clearInterval(alertInterval);
    clearInterval(breachInterval);
    clearInterval(timeUpdateInterval);
    
    if (lockdownScreen) {
        lockdownScreen.style.display = 'flex'; 
    }
    
    document.body.style.overflow = 'hidden'; 

    let countdownValue = 5; //Webpage deletion timer (in seconds)

    if (amnesticTimerEl) {
        amnesticTimerEl.textContent = countdownValue;

        const countdownInterval = setInterval(() => {
            countdownValue--;
            
            if (countdownValue > 0) {
                amnesticTimerEl.textContent = countdownValue;
            } else if (countdownValue === 0) {
                amnesticTimerEl.textContent = 'EXECUTING';
            } else {
                clearInterval(countdownInterval);
                
                localStorage.removeItem('scpAppState'); 
                window.location.replace('404.html'); 
            }
        }, 1000); 
    }
}


function triggerBreach() {
    if (isBreachActive) return;
    
    isBreachActive = true; 
    
    if (siteStatusEl) {
        siteStatusEl.textContent = "SITE-██ STATUS: RED - CONTAINMENT BREACH";
        siteStatusEl.classList.remove('status-yellow', 'status-green');
        siteStatusEl.classList.add('status-red');
        siteStatusEl.style.color = '#ff0000'; 
        siteStatusEl.style.borderColor = '#ff0000'; 
    }

    logAlert("⚠️ **CRITICAL ALERT:** KETER-CLASS CONTAINMENT BREACH DETECTED. ALL PERSONNEL REPORT TO NEAREST EVACUATION BUNKER.");
    
    saveAppState();
    
    setTimeout(startLockdownCountdown, 60000);  
}


function runAlertCycle() {
    if (isBreachActive) {
        return; 
    }

    if (availableAlerts.length === 0) {
        replenishAlerts();
    }
    
    const actionMessage = availableAlerts.pop();
    const completionMessage = ALERT_MAPPING[actionMessage];
    
    logAlert(actionMessage);
    
    const isTransferAlert = actionMessage.includes("TRANSFER") || actionMessage.includes("TRANSIT");

    if (isTransferAlert && siteStatusEl) {
        siteStatusEl.textContent = "SITE-██ STATUS: YELLOW - HIGH CAUTION";
        siteStatusEl.classList.remove('status-red', 'status-green');
        siteStatusEl.classList.add('status-yellow');
        siteStatusEl.style.color = '#ffff00'; 
        siteStatusEl.style.borderColor = '#ffff00'; 
        saveAppState();
    }
    
    if (completionMessage) {
        setTimeout(() => {
            if (isBreachActive) return;

            logAlert(completionMessage);
            
            if (isTransferAlert && siteStatusEl) {
                siteStatusEl.textContent = "SITE-██ STATUS: GREEN";
                siteStatusEl.classList.remove('status-yellow', 'status-red');
                siteStatusEl.style.color = ''; 
                siteStatusEl.style.borderColor = ''; 
                saveAppState();
            }
        }, 600000); // 10 minute alert completion time
    }
}

function runBreachCycle() {
    if (isBreachActive) return;
    
    if (Math.random() < CONTAINMENT_BREACH_CHANCE) {
        triggerBreach();
    }
}

function initializePage() {
    loadAppState();
    
    timeUpdateInterval = setInterval(updateTime, 1000); 
    updateTime();
    
    if (!isBreachActive) {
        alertInterval = setInterval(runAlertCycle, 40000); // New Alert (40 seconds)
        breachInterval = setInterval(runBreachCycle, 60000); // Check for breach (60 seconds)
    }

    if (menuToggle && sidebar) {
        menuToggle.addEventListener('click', () => {
            sidebar.classList.toggle('open');
        });
    }

    if (notificationIcon && alertDropdown) {
        notificationIcon.addEventListener('click', () => {
            alertDropdown.classList.toggle('hidden');
            
            if (!alertDropdown.classList.contains('hidden')) {
                unreadAlertCount = 0;
                if (alertCountEl) alertCountEl.classList.add('hidden');
                saveAppState(); 
            }
        });
    }
}

replenishAlerts();

if (splashScreen && mainContent) {
    
    splashScreen.addEventListener('click', () => {
        splashScreen.style.opacity = '0';
        setTimeout(() => {
            splashScreen.style.display = 'none';
            mainContent.classList.remove('hidden');
            mainContent.style.opacity = '1';
            
            initializePage();
        }, 500);
    });
} else {
    initializePage();
}