const splashScreen = document.getElementById('splash-screen');
const mainContent = document.getElementById('main-content');
const serverTimeEl = document.getElementById('server-time');
const siteStatusEl = document.getElementById('site-status');
const lockdownScreen = document.getElementById('lockdown-screen');
const amnesticTimerEl = document.getElementById('amnestic-timer'); 
const notificationIcon = document.getElementById('notification-icon');
const alertCountEl = document.getElementById('alert-count'); 
const alertDropdown = document.getElementById('alert-dropdown');
const alertList = document.getElementById('alert-list');
const noAlertsMsg = document.getElementById('no-alerts-msg');
const menuToggle = document.getElementById('menu-toggle');
const sidebar = document.getElementById('sidebar');
const toastNotification = document.getElementById('toast-notification');

let timeUpdateInterval;
let alertInterval;
let breachInterval;
let unreadAlertCount = 0;
let availableAlerts = []; 
let isBreachActive = false;

// Containment breach chance (5% chance per minute)
const CONTAINMENT_BREACH_CHANCE = 1; 

const ALERT_MAPPING = {
    "PERSONNEL TRANSFER: D-Class rotation complete. Amnestics administered and documentation finalized for new intake.": 
        "PERSONNEL TRANSFER COMPLETE: All D-Class intake procedures finalized. Personnel and documentation filed.",
    "PERSONNEL ALERT: Dr. ██████ is relocating to Site-42. Project files 77-A and 77-B must be archived by 09:00 hours.": 
        "PERSONNEL TRANSFER COMPLETE: Dr. ██████'s project files archived and transfer to Site-42 confirmed.",
    "PERSONNEL TRANSFER: Dr. Alistair Rigsby moving from Site-88 to Site-19. All security passes for Site-88 are now revoked for Dr. Rigsby.": 
        "PERSONNEL TRANSFER COMPLETE: Dr. Alistair Rigsby's transit finalized. Welcome to Site-19.",
    "PERSONNEL TRANSFER: Class D rotation complete in Sector 5. All D-Class intake procedures pending final documentation review.": 
        "PERSONNEL TRANSFER COMPLETE: All D-Class intake procedures finalized and documentation filed in Sector 5.",
    "PERSONNEL ALERT: O5-10's secure communications link is rerouting from Site-01 to Sector 04-A. Temporary comms blackout expected (09:00 - 10:30 hours).": 
        "PERSONNEL TRANSFER COMPLETE: O5-10 secure link successfully rerouted to Sector 04-A. Communications restored.",
    "PERSONNEL TRANSFER: Dr. Jack Bright has been temporarily reassigned to Site-65 for Keter containment analysis. Revoke his access to Level 3 R&D labs.": 
        "PERSONNEL TRANSFER COMPLETE: Dr. Bright confirmed at Site-65. Security permissions updated.",

    "TRANSFER INITIATED: SCP-682 (Keter-Class, Hard-to-Destroy Reptile) scheduled for immediate containment transfer from Sector 07-B to Deep Containment Site 33. All non-essential personnel must vacate Sector 07-B perimeter.": 
        "TRANSFER COMPLETE: SCP-682 safely secured at Deep Containment Site 33. All associated lockdown protocols terminated.",
    "TRANSFER ALERT: Specialized Containment Unit 4 (SCU-4) in transit carrying SCP-173 ('The Sculpture'). Maintain line-of-sight protocol until transit is concluded. Do NOT blink.": 
        "TRANSFER COMPLETE: SCP-173 safely secured. Line-of-sight protocol terminated.",
    "TRANSFER ALERT: Mobile Containment Unit (MCU) 1-4 transporting SCP-789. Site-45 perimeter restricted. Do not approach the designated transport corridor.": 
        "TRANSFER COMPLETE: SCP-789 successfully secured at Site-17. MCU 1-4 returning to hangar. All movement restrictions lifted.",
    "TRANSFER ALERT: SCU-7 operating near Sector 2. Containment of biological anomaly SCP-939 ('The Voice of the Decedents') in transit. Respiratory hazard protocols active within 50 meters.": 
        "TRANSFER COMPLETE: SCP-939 safely secured. All respiratory hazard protocols terminated in Sector 2.",
    "TRANSFER ALERT: Standard Euclid-Class Object SCP-049 ('Plague Doctor') is being moved to a deeper containment cell. Personnel must observe 30-meter exclusion zone.": 
        "TRANSFER COMPLETE: SCP-049 is successfully secured in the new cell. Exclusion zone protocols terminated.",
    "TRANSFER ALERT: Highly unstable object SCP-076-2 (Designate: 'Able') temporarily stored in Vault 3. Minimize magnetic emissions and maintain 24-hour MTF guard detail.":
        "TRANSFER COMPLETE: SCP-076-2 secured and magnetic emissions stabilized in Vault 3. MTF guard detail established.",
    "TRANSFER ALERT: Safe-Class Object SCP-914 ('The Clockwork') is being moved to Research Lab 4 for testing. Researchers must wear hazmat suits for residue analysis.": 
        "TRANSFER COMPLETE: SCP-914 safely repositioned to Research Lab 4. Containment integrity verified.",
    "TRANSFER ALERT: Safe-Class Object SCP-500 ('Panacea') container being transferred to the Medical Wing storage. Level 3 clearance required for proximity access.": 
        "TRANSFER COMPLETE: SCP-500 secured in Medical Wing storage. Proximity access restrictions lifted.",
    "TRANSFER INITIATED: Low-Risk Non-Anomalous Object 112 (LNAO-112) moving from Lab 3 to Archive D. Expect minor delays in Sector Gamma traffic.": 
        "TRANSFER COMPLETE: LNAO-112 archived. Sector Gamma traffic flow normalized.",
    "TRANSFER ALERT: High-value memetic data package (Project CERES) being uploaded to off-site secure storage. Local network stability may drop 10% for 30 minutes.": 
        "TRANSFER COMPLETE: Project CERES data package fully uploaded and verified. Local network stability restored.",

    "MAINTENANCE NOTICE: Site-199 HVAC systems offline for 2 hours. Personnel should expect temperature fluctuations in Sector Delta.": 
        "MAINTENANCE COMPLETE: Site-199 HVAC systems are back online. Temperature stabilization proceeding normally.",
    "MAINTENANCE NOTICE: Primary Generator 5 scheduled for cold-swap replacement in Sector Beta. Expect temporary low-frequency hum and minor power flicker (20:00 - 22:00 hours).": 
        "MAINTENANCE COMPLETE: Primary Generator 5 replacement finalized. Power grid operating at 100% efficiency.",
    "MAINTENANCE NOTICE: Water Reclamation Plant B offline for filter replacement. Non-potable water supply restricted for 4 hours.": 
        "MAINTENANCE COMPLETE: Water Reclamation Plant B online. Water services operating normally.",
    "MAINTENANCE NOTICE: Fire Suppression System check in Sector Epsilon. Do not tamper with fire alarms during 14:00 - 16:00 window.": 
        "MAINTENANCE COMPLETE: Fire Suppression System check passed in Sector Epsilon.",
    "MAINTENANCE NOTICE: Server Farm 3 scheduled for firmware update. Access to historical logs will be unavailable for 90 minutes.": 
